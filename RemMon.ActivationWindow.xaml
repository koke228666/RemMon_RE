<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="RemMon.ActivationWindow" x:ClassModifier="internal" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Активация RemMon" Width="520" MinWidth="520" SizeToContent="Height" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True" Background="#00FFFFFF" FontFamily="Segoe UI" UseLayoutRounding="True" SnapsToDevicePixels="True" xmlns:remmon="clr-namespace:RemMon;assembly=RemMon">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <Style x:Key="{x:Type Button}" TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="#FFE8F0FA" />
        <Setter Property="Background" Value="#FF111B2A" />
        <Setter Property="BorderBrush" Value="#FF31455F" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border Name="Root" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" CornerRadius="6">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter TargetName="Root" Property="Border.BorderBrush" Value="#FF58A6FF" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter Property="UIElement.Opacity" Value="0.55" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="{x:Type TextBox}" TargetType="{x:Type TextBox}">
        <Setter Property="Foreground" Value="#FFE8F0FA" />
        <Setter Property="TextBoxBase.CaretBrush" Value="#FF58A6FF" />
        <Setter Property="Background" Value="#FF111B2A" />
        <Setter Property="BorderBrush" Value="#FF31455F" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type TextBox}">
              <Border Name="Root" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" CornerRadius="7">
                <ScrollViewer Name="PART_ContentHost" Margin="{TemplateBinding Control.Padding}" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsKeyboardFocusWithin" Value="True">
                  <Setter TargetName="Root" Property="Border.BorderBrush" Value="#FF58A6FF" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Border Background="#FF07111B" BorderBrush="#FF31455F" BorderThickness="1" CornerRadius="10" Padding="26" MouseLeftButtonDown="Shell_MouseLeftButtonDown">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <TextBlock Text="Активация RemMon" Foreground="#FFE8F0FA" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,10" />
      <TextBlock Grid.Row="1" Text="Введите лицензионный ключ для продолжения." Foreground="#FFB8C4D4" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,18" />
      <TextBox Name="LicenseKeyBox" Grid.Row="2" Height="46" FontSize="15" CharacterCasing="Upper" Padding="12,0" VerticalContentAlignment="Center" KeyDown="LicenseKeyBox_KeyDown" />
      <TextBlock Name="StatusText" Grid.Row="3" Text="" Foreground="#FFB8C4D4" TextWrapping="Wrap" MinHeight="20" Margin="0,14,0,12" />
      <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Name="ActivateButton" Content="Активировать" MinWidth="130" Padding="16,9" Margin="6,0,0,0" Foreground="#FFFFFFFF" Background="#FF1677FF" BorderBrush="#FF2E8BFF" Click="ActivateButton_Click" />
        <Button Content="Выход" MinWidth="110" Padding="16,9" Margin="8,0,0,0" Click="ExitButton_Click" />
      </StackPanel>
    </Grid>
  </Border>
</Window>