<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="RemMon.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:RemMon" Title="RemMon" Width="300" Height="586" Left="10" Top="10" WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True" Background="#00FFFFFF" Topmost="True" ShowInTaskbar="False" WindowStartupLocation="Manual" UseLayoutRounding="True" SnapsToDevicePixels="True">
  <Border Name="OverlayRoot" Background="#D0080808" CornerRadius="10" Padding="12">
    <Grid>
      <StackPanel Name="LineOverlayRootPanel" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Left">
        <StackPanel Name="LineOverlayPanel" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" />
        <StackPanel Name="LineOverlayFooterPanel" Orientation="Horizontal" Margin="0,4,0,0" HorizontalAlignment="Left">
          <TextBlock Name="LineBrandText" FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center">
            <Run Text="Ремский" Foreground="#FFF2F2F2" /> <Run Text=" Мониторинг" Foreground="#FFFF6A00" /></TextBlock>
          <TextBlock Name="LineFreeVersionText" Text="Бесплатная версия" Foreground="#CCFFFFFF" FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Visibility="Collapsed" />
        </StackPanel>
      </StackPanel>
      <StackPanel Name="OverlayStack">
        <Grid Name="BrandPanel" Margin="0,0,0,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center">
            <TextBlock Name="BrandText" FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="21" TextAlignment="Left" LineHeight="22">
              <Run Text="Ремский" Foreground="#FFF2F2F2" />
              <LineBreak />
              <Run Text="Мониторинг" Foreground="#FFFF6A00" />
            </TextBlock>
            <TextBlock Name="BrandUrlText" Text="r-mont.ru" Foreground="#FFFF6A00" FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="14" Margin="0,2,0,0" />
          </StackPanel>
          <Image Name="BrandIcon" Grid.Column="1" Source="/brandpic.png" Height="64" Margin="12,0,0,0" HorizontalAlignment="Right" VerticalAlignment="Center" />
        </Grid>
        <StackPanel Name="FpsBlockPanel">
          <TextBlock Name="TimeText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="16" Text="00:00:00" TextAlignment="Left" HorizontalAlignment="Left" Margin="0,0,0,4" />
          <Grid Name="FpsHeaderPanel" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,2">
              <TextBlock Name="FpsLabelText" Text="FPS" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="24" VerticalAlignment="Bottom" />
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
              <TextBlock Name="FpsValueText" Foreground="#FFFF6A00" FontFamily="Segoe UI" FontWeight="Bold" FontSize="24" Text="N/A" TextAlignment="Right" />
            </StackPanel>
          </Grid>
          <TextBlock Name="FpsDetailsText" Foreground="#FFE7E7E7" FontFamily="Segoe UI" FontSize="12" Text="AVG: N/A   1% Low: N/A   0.1% Low: N/A   FT: N/A" />
          <TextBlock Name="GameText" Margin="0,2,0,9" Foreground="#FFAAAAAA" FontFamily="Segoe UI" FontSize="11" Text="Окно: N/A" />
          <TextBlock Name="RenderInfoText" Margin="0,0,0,8" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="12" Text="API: N/A  N/A" />
          <Rectangle Name="TopSeparator" Height="1" Fill="#33FFFFFF" Margin="0,0,0,9" />
        </StackPanel>
        <StackPanel Name="GpuBlockPanel">
          <StackPanel Orientation="Horizontal">
            <TextBlock Name="GpuTitleText" Foreground="#FF35D463" FontFamily="Segoe UI" FontWeight="Bold" FontSize="15" Text="GPU" />
          </StackPanel>
          <Grid Name="GpuRowsGrid" Margin="0,4,0,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Name="GpuLoadLabel" Text="Загрузка" Foreground="#FF35D463" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="GpuTempLabel" Text="Температура" Foreground="#FF35D463" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="GpuHotspotTempLabel" Text="Темп. горячей точки" Foreground="#FF35D463" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="GpuVramTempLabel" Text="Температура памяти" Foreground="#FF35D463" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="GpuClockLabel" Text="Частота" Foreground="#FF35D463" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="GpuMemoryClockLabel" Text="Память GPU" Foreground="#FF35D463" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="GpuVoltageLabel" Text="Напряжение" Foreground="#FF35D463" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="GpuPowerLabel" Text="Потребление" Foreground="#FF35D463" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="GpuFanRpmLabel" Text="Обороты вент." Foreground="#FF35D463" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="GpuFanPercentLabel" Text="Обороты вент. в %" Foreground="#FF35D463" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="VramLabel" Text="Видеопамять" Foreground="#FF35D463" FontFamily="Segoe UI" FontSize="13" />
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
              <TextBlock Name="GpuLoadText" Foreground="#FFFF4C4C" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="GpuTempText" Foreground="#FFFF4C4C" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="GpuHotspotTempText" Foreground="#FFFF4C4C" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="GpuVramTempText" Foreground="#FFFF4C4C" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="GpuClockText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="GpuMemoryClockText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="GpuVoltageText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="GpuPowerText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="GpuFanRpmText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="GpuFanPercentText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="VramText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
            </StackPanel>
          </Grid>
          <Rectangle Name="GpuSeparator" Height="1" Fill="#33FFFFFF" Margin="0,0,0,9" />
        </StackPanel>
        <StackPanel Name="CpuBlockPanel">
          <StackPanel Orientation="Horizontal">
            <TextBlock Name="CpuTitleText" Foreground="#FF58A6FF" FontFamily="Segoe UI" FontWeight="Bold" FontSize="15" Text="CPU" />
          </StackPanel>
          <Grid Name="CpuRowsGrid" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Name="CpuLoadLabel" Text="Загрузка" Foreground="#FF58A6FF" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="CpuTempLabel" Text="Температура" Foreground="#FF58A6FF" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="CpuClockLabel" Text="Частота" Foreground="#FF58A6FF" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="CpuEfficiencyClockLabel" Text="Частота E ядер" Foreground="#FF58A6FF" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="CpuPowerLabel" Text="Потребление" Foreground="#FF58A6FF" FontFamily="Segoe UI" FontSize="13" />
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
              <TextBlock Name="CpuLoadText" Foreground="#FFFFE066" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="CpuTempText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="CpuClockText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="CpuEfficiencyClockText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="CpuPowerText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
            </StackPanel>
          </Grid>
          <StackPanel Name="CpuCoreClockRowsPanel" Margin="0,6,0,6" />
          <Border Name="CpuCoreLoadGraphHost" Height="52" Margin="0,0,0,8" ClipToBounds="True">
            <Canvas Name="CpuCoreLoadGraphCanvas" Height="52" ClipToBounds="True" Background="#00FFFFFF" />
          </Border>
          <Border Name="CpuRowsBottomSpacer" Height="10" />
          <Rectangle Name="CpuSeparator" Height="1" Fill="#33FFFFFF" Margin="0,0,0,9" />
        </StackPanel>
        <StackPanel Name="RamBlockPanel">
          <StackPanel Orientation="Horizontal">
            <TextBlock Name="RamTitleText" Text="ОЗУ" Foreground="#FFB58CFF" FontFamily="Segoe UI" FontWeight="Bold" FontSize="15" />
          </StackPanel>
          <Grid Name="RamRowsGrid" Margin="0,4,0,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Name="RamUsedLabel" Text="Использовано" Foreground="#FFB58CFF" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="RamLoadLabel" Text="Загрузка" Foreground="#FFB58CFF" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="RamSpeedLabel" Text="Скорость" Foreground="#FFB58CFF" FontFamily="Segoe UI" FontSize="13" />
              <StackPanel Name="RamTemperatureLabelsPanel" />
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
              <TextBlock Name="RamUsedText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="RamLoadText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="RamSpeedText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <StackPanel Name="RamTemperatureValuesPanel" HorizontalAlignment="Right" />
            </StackPanel>
          </Grid>
          <Rectangle Name="RamSeparator" Height="1" Fill="#33FFFFFF" Margin="0,0,0,9" />
        </StackPanel>
        <StackPanel Name="StatsBlockPanel">
          <StackPanel Orientation="Horizontal">
            <TextBlock Name="StatsTitleText" Text="Статистика" Foreground="#FFFFA64D" FontFamily="Segoe UI" FontWeight="Bold" FontSize="15" />
          </StackPanel>
          <Grid Name="StatsRowsGrid" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Name="StatsGpuMinMaxLabel" Text="Мин/Макс GPU" Foreground="#FFFFA64D" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="StatsCpuMinMaxLabel" Text="Мин/Макс CPU" Foreground="#FFFFA64D" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="StatsVramMinMaxLabel" Text="Мин/Макс VRAM" Foreground="#FFFFA64D" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="StatsHotspotMinMaxLabel" Text="Мин/Макс Hotspot" Foreground="#FFFFA64D" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="StatsGpuVoltageMinMaxLabel" Text="Мин/Макс напр. GPU" Foreground="#FFFFA64D" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="StatsGpuPowerMinMaxLabel" Text="Мин/Макс потр. GPU" Foreground="#FFFFA64D" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="StatsCpuPowerMinMaxLabel" Text="Мин/Макс потр. CPU" Foreground="#FFFFA64D" FontFamily="Segoe UI" FontSize="13" />
              <StackPanel Name="StatsRamTemperatureLabelsPanel" />
              <TextBlock Name="StatsStutterStateLabel" Text="Состояние" Foreground="#FFFFA64D" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="StatsStutterCountLabel" Text="Количество статтеров" Foreground="#FFFFA64D" FontFamily="Segoe UI" FontSize="13" />
              <TextBlock Name="StatsLastStutterLabel" Text="Последний статтер" Foreground="#FFFFA64D" FontFamily="Segoe UI" FontSize="13" />
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
              <TextBlock Name="StatsGpuMinMaxText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="StatsCpuMinMaxText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="StatsVramMinMaxText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="StatsHotspotMinMaxText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="StatsGpuVoltageMinMaxText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="StatsGpuPowerMinMaxText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <TextBlock Name="StatsCpuPowerMinMaxText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
              <StackPanel Name="StatsRamTemperatureValuesPanel" HorizontalAlignment="Right" />
              <TextBlock Name="StatsStutterStateText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="Плавно" TextAlignment="Right" />
              <TextBlock Name="StatsStutterCountText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="0" TextAlignment="Right" />
              <TextBlock Name="StatsLastStutterText" Foreground="#FFF2F2F2" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13" Text="N/A" TextAlignment="Right" />
            </StackPanel>
          </Grid>
          <Rectangle Name="StatsSeparator" Height="1" Fill="#33FFFFFF" Margin="0,9,0,0" />
        </StackPanel>
        <StackPanel Name="FrameTimeGraphPanel" Margin="0,10,0,0">
          <Grid Name="FrameTimeGraphHost" Height="52">
            <Grid.RowDefinitions>
              <RowDefinition Height="*" />
              <RowDefinition Height="14" />
            </Grid.RowDefinitions>
            <local:FrameTimeGraphView x:Name="FrameTimeGraphCanvas" ClipToBounds="True" />
            <TextBlock Name="FrameTimeGraphLabel" Grid.Row="1" Margin="0,1,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Foreground="#FFFF6A5E" FontFamily="Segoe UI" FontWeight="Bold" FontSize="11" Text="N/A ms" />
          </Grid>
          <TextBlock Name="FreeVersionText" Text="Бесплатная версия" Foreground="#CCFFFFFF" FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="24" Margin="0,8,0,0" HorizontalAlignment="Left" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Visibility="Collapsed" />
          <Rectangle Name="GraphSeparator" Height="1" Fill="#33FFFFFF" Margin="0,8,0,0" />
        </StackPanel>
      </StackPanel>
    </Grid>
  </Border>
</Window>